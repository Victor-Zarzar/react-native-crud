{
	"name": "react-native-crud",
	"main": "expo-router/entry",
	"version": "1.0.0",
	"author": "victorzarzar (https://github.com/Victor-Zarzar)",
	"repository": "https://github.com/Victor-Zarzar/react-native-crud",
	"bugs": {
		"url": "https://github.com/Victor-Zarzar/react-native-crud/issues"
	},
	"scripts": {
		"dev": "expo start -c",
		"dev:client": "expo start --dev-client",
		"android": "expo start -c --android",
		"ios": "expo start -c --ios",
		"web": "expo start -c --web",
		"db:generate": "drizzle-kit generate",
		"db:studio": "drizzle-kit studio",
		"clean": "rm -rf .expo node_modules ios android",
		"prebuild": "expo prebuild --clean",
		"ios:native": "expo run:ios",
		"android:native": "expo run:android",
		"lint": "biome check .",
		"lint:fix": "biome check . --write",
		"format": "biome format . --write",
		"typecheck": "tsc --noEmit",
		"test": "bun test"
	},
	"dependencies": {
		"@expo/metro-runtime": "~6.1.2",
		"@react-native-async-storage/async-storage": "2.2.0",
		"@react-navigation/native": "^7.1.31",
		"@rn-primitives/avatar": "^1.2.0",
		"@rn-primitives/label": "^1.2.0",
		"@rn-primitives/popover": "^1.2.0",
		"@rn-primitives/portal": "~1.3.0",
		"@rn-primitives/separator": "^1.2.0",
		"@rn-primitives/slot": "^1.2.0",
		"@rn-primitives/tabs": "^1.2.0",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"drizzle-orm": "^0.45.1",
		"expo": "~54.0.29",
		"expo-constants": "~18.0.12",
		"expo-crypto": "~15.0.8",
		"expo-linking": "~8.0.10",
		"expo-localization": "~17.0.8",
		"expo-router": "~6.0.19",
		"expo-splash-screen": "~31.0.12",
		"expo-sqlite": "^16.0.10",
		"expo-status-bar": "~3.0.9",
		"expo-system-ui": "~6.0.9",
		"i18next": "^25.8.13",
		"lucide-react-native": "^0.575.0",
		"nativewind": "^4.2.2",
		"react": "19.1.0",
		"react-dom": "19.1.0",
		"react-i18next": "^16.5.4",
		"react-native": "0.81.5",
		"react-native-reanimated": "~4.1.1",
		"react-native-safe-area-context": "~5.6.0",
		"react-native-screens": "~4.16.0",
		"react-native-svg": "15.12.1",
		"react-native-web": "^0.21.2",
		"react-native-worklets": "0.5.1",
		"tailwind-merge": "^3.5.0",
		"tailwindcss": "^3.4.17",
		"tailwindcss-animate": "^1.0.7"
	},
	"devDependencies": {
		"@babel/core": "^7.26.0",
		"@biomejs/biome": "^2.4.4",
		"@types/bun": "^1.3.9",
		"@types/react": "~19.1.10",
		"babel-plugin-inline-import": "^3.0.0",
		"drizzle-kit": "^0.31.9",
		"typescript": "~5.9.3"
	},
	"private": true
}
